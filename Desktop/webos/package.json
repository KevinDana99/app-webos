{
  "name": "carpeta-sin-título",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "build-app": "cd ./app && ares-package .",
    "install-app": "cd ./app && ares-install -d tele2 *.ipk",
    "launch-app": "cd ./app && ares-launch -d tele2 com.crunchyroll.webos"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
